# Flutter app environment — copy to .env and fill in values
# NEVER commit .env with real values

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API base URL — the Cloudflare Worker (vanguard-api).
API_BASE_URL=https://vanguard-api.your-subdomain.workers.dev

# Firebase config is in google-services.json (android/) — not here
