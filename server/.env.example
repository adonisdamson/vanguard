# Railway server environment — set these in Railway dashboard, never commit real values

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# WARNING: service_role key bypasses all RLS — keep it ONLY here, never in Flutter
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

PORT=3000

# One-time secret for POST /api/admin/bootstrap-superadmin
# Set any long random string in Railway, call the endpoint once to create admin, then delete this var.
BOOTSTRAP_SECRET=your-one-time-bootstrap-secret

# Optional — GitHub personal access token (read-only: contents permission).
# Without this: 60 GitHub API requests/hour (shared across all users).
# With this: 5000/hour. Set in Railway dashboard to prevent download failures at scale.
GITHUB_TOKEN=
